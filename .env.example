# LLM providers — add the ones you want to evaluate
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...              # Google AI Studio — aistudio.google.com/apikey

# Langfuse observability (get free keys at https://cloud.langfuse.com or run locally)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com   # or http://localhost:3000 if self-hosted

# Eval settings
DEFAULT_MODEL=openai/gpt-4o-mini           # cheap and fast for iteration
DATABASE_PATH=./datasets/ecommerce.duckdb

# LLM-as-judge scorer — can be a different (stronger) model than the one being evaluated
JUDGE_MODEL=openai/gpt-4o-mini             # or openai/gpt-4o for stricter judgments

# Embedding model for few_shot_dynamic strategy (used to find similar examples)
EMBEDDING_MODEL=openai/text-embedding-3-small
